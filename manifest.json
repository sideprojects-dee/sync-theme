{
  "manifest_version": 3,
  "name": "Sync Theme",
  "version": "0.1.0",
  "description": "Switches Slack and Grafana between light and dark to match your system theme. Works only on Slack and Grafana.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Sync Theme",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "permissions": ["storage", "scripting"],
  "optional_host_permissions": ["https://*/*"],
  "content_scripts": [
    {
      "matches": [
        "https://*.slack.com/*",
        "https://slack.com/*",
        "https://*.grafana.net/*",
        "https://*.grafana.com/*",
        "https://grafana.com/*"
      ],
      "js": ["src/content/bootstrap.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/content/*.js", "src/lib/*.js"],
      "matches": ["https://*/*"]
    }
  ],
  "minimum_chrome_version": "116"
}
